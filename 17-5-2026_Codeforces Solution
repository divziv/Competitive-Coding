Solution:
#include <bits/stdc++.h>
using namespace std;

int main()
{
    int k;
    cin >> k;

    string input, output = "";
    cin >> input;

    const int size = 26;
    int letters[size] = {0};

    for(int i = 0; i < input.size(); i++)
    {
        letters[input[i] - 'a']++;
    }

    for(int i = 0; i < size; i++)
    {
        if(letters[i] == 0)
        {
            continue;
        }
        else if(letters[i] % k == 0)
        {
            for(int j = 0; j < letters[i] / k; j++)
            {
                output += char('a' + i);
            }
        }
        else
        {
            cout << -1 << "\n";
            return 0;
        }
    }

    for(int i = 0; i < k; i++)
    {
        cout << output;
    }

    cout << "\n";
    return 0;
}
