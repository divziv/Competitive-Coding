Solution:
#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n, m;
    cin >> n >> m;

    vector<string> board(n);

    for(int i = 0; i < n; i++)
    {
        cin >> board[i];
    }

    for(int row = 0; row < n; row++)
    {
        for(int col = 0; col < m; col++)
        {
            if(board[row][col] == '.')
            {
                if((row + col) % 2)
                    board[row][col] = 'B';
                else
                    board[row][col] = 'W';
            }
            cout << board[row][col];
        }
        cout << "\n";
    }

    return 0;
}
