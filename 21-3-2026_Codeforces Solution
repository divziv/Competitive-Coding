#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        string a, b;
        cin >> a >> b;

        string s;

        if(a.back() == b.back())
        {
            if(a.size() == b.size())
            {
                s = "=";
            }
            else if(a.back() == 'S')
            {
                s = (a.size() > b.size()) ? "<" : ">";
            }
            else
            {
                s = (a.size() > b.size()) ? ">" : "<";
            }
        }
        else
        {
            if(a.back() == 'L') s = ">";
            else if(b.back() == 'L') s = "<";
            else if(a.back() == 'M') s = ">";
            else s = "<";
        }

        cout << s << "\n";
    }

    return 0;
}
