Solution:
#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long n, k;
        cin >> n >> k;

        long long a = k * ((n - 1) / 2);
        long long b = 1 + n / 2;
        long long s = 0;

        for(long long i = 0; i < n * k; i++)
        {
            int x;
            cin >> x;

            if(i < a)
            {
                continue;
            }
            else if((i - a) % b == 0)
            {
                s += x;
            }
        }

        cout << s << "\n";
    }

    return 0;
}
