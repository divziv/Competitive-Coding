#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        long long o = 0, z = 0;

        for(int i = 0; i < n; i++) 
        {
            long long x;
            cin >> x;
            if(x == 0) 
                z++;
            if(x == 1) 
                o++;
        }

        long long s = (1LL << z) * o;
        cout << s << "\n";
    }

    return 0;
}
