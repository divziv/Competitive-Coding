Solution:
#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        string b;
        cin >> b;

        vector<bool> vis(26, false);

        for(char c : b)
            vis[c - 'a'] = true;

        string a = "";
        for(int i = 0; i < 26; i++)
            if(vis[i])
                a += char('a' + i);

        char mp[26];

        int k = a.size();
        for(int i = 0; i < k; i++)
            mp[a[i] - 'a'] = a[k - 1 - i];

        for(char &c : b)
            c = mp[c - 'a'];

        cout << b << "\n";
    }
}
