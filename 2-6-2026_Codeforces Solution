#include<bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long a, b, n, S;
        cin >> a >> b >> n >> S;

        long long use = min(a, S / n);
        long long rem = S - use * n;

        if(rem <= b)
        {
            cout << "YES\n";
        }
        else
        {
            cout << "NO\n";
        }
    }

    return 0;
}
