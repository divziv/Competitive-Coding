#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long n;
        cin >> n;

        long long s = n * (n + 1) / 2;

        long long x = 1;
        while(x <= n)
        {
            s -= 2 * x;
            x *= 2;
        }

        cout << s << "\n";
    }

    return 0;
}
