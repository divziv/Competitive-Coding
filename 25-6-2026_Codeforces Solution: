#include <bits/stdc++.h>
using namespace std;

int main()
{
    const int l = 26;
    long t;
    cin >> t;

    while(t--)
    {
        long n;
        cin >> n;
        string s;
        cin >> s;

        vector<bool> v(l, 0);
        v[s[0] - 'a'] = 1;
        v[s.back() - 'a'] = 1;

        bool f = false;

        for(long i = 1; !f && i < (long)s.size() - 1; i++)
        {
            int x = s[i] - 'a';
            if(v[x])
            {
                f = true;
            }
            v[x] = 1;
        }

        cout << (f ? "YES" : "NO") << '\n';
    }

    return 0;
}
