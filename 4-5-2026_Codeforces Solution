#include <bits/stdc++.h>
using namespace std;

long gcd(long a, long b) {
    return (b == 0) ? a : gcd(b, a % b);
}

int main() {
    long t;
    cin >> t;

    while(t--) {
        long n;
        cin >> n;

        vector<long> a(n);
        for(long i = 0; i < n; i++) 
        {
            cin >> a[i];
        }

        bool f = false;

        for(long i = 0; i < n && !f; i++) 
        {
            for(long j = i + 1; j < n && !f; j++) 
            {
                if(gcd(a[i], a[j]) <= 2) 
                {
                    f = true;
                }
            }
        }

        cout << (f ? "Yes\n" : "No\n");
    }

    return 0;
}
