#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        long long n, l, u;
        cin >> n >> l >> u;

        vector<long long> a(n);
        for(long long i = 0; i < n; i++) 
        {
            cin >> a[i];
        }

        sort(a.begin(), a.end());

        long long cu = 0;
        long long left = 0, right = n - 1;
        while(left < right) 
        {
            if(a[left] + a[right] > u) 
            {
                right--;
            } 
            else 
            {
                cu += right - left;
                left++;
            }
        }

        long long cl = 0;
        left = 0, right = n - 1;
        long long s = l - 1;
        while(left < right) 
        {
            if(a[left] + a[right] > s) 
            {
                right--;
            } 
            else 
            {
                cl += right - left;
                left++;
            }
        }

        cout << (cu - cl) << "\n";
    }

    return 0;
}
