Solution:
#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n;
        long long x;
        cin >> n >> x;

        vector<long long> a(n);
        for(int i = 0; i < n; i++)
        {
            cin >> a[i];
        }

        long long mini = a[0] - x;
        long long maxi = a[0] + x;
        int c = 0;

        for(int i = 1; i < n; i++)
        {
            mini = max(mini, a[i] - x);
            maxi = min(maxi, a[i] + x);

            if(mini > maxi)
            {
                c++;
                mini = a[i] - x;
                maxi = a[i] + x;
            }
        }

        cout << c << "\n";
    }

    return 0;
}
