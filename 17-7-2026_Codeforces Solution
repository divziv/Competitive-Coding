#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        vector<int> a(n);
        for(int i = 0; i < n; i++)
            cin >> a[i];

        int s = 0;
        int m = a[n - 1];

        for(int i = n - 2; i >= 0; i--) 
        {
            if(a[i] > m)
                s++;
            else
                m = a[i];
        }

        cout << s << "\n";
    }

    return 0;
}
