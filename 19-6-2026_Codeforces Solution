#include <bits/stdc++.h>
using namespace std;

int main()
{
    long t;
    cin >> t;
    while(t--)
    {
        long n;
        cin >> n;
        for(long i = 1; i <= n; i += 2)
        {
            cout << i << " ";
        }
        for(long i = n - n % 2; i > 1; i -= 2)
        {
            cout << i << " ";
        }
        cout << "\n";
    }
    return 0;
}
