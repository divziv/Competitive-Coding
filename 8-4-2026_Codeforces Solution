#include <bits/stdc++.h>
using namespace std;

int main()
{
    long t;
    cin >> t;

    while(t--)
    {
        long n;
        cin >> n;

        vector<long> a(n);
        long long s = 0;

        for(long i = 0; i < n; i++)
        {
            cin >> a[i];
            s += a[i];
        }

        if(s % n != 0)
        {
            cout << -1 << '\n';
            continue;
        }

        long num = s / n;
        long k = 0;

        for(long i = 0; i < n; i++)
        {
            if(a[i] > num)
            {
                k++;
            }
        }

        cout << k << "\n";
    }

    return 0;
}
