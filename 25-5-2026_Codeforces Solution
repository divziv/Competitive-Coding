#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        string s;
        cin >> s;

        string d = "";

        int i = n - 1;

        while(i >= 0) 
        {
            int r = 0;

            if(s[i] == '0') 
            {
                r = 10 * (s[i - 2] - '0') + (s[i - 1] - '0');
                i -= 3;
            } 
            else 
            {
                r = s[i] - '0';
                i--;
            }

            char c = 'a' + r - 1;
            d = c + d;
        }

        cout << d << "\n";
    }

    return 0;
}
