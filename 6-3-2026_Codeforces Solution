#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    for (int r = 0; r <= 2 * n; r++) {
        int d = min(r, 2 * n - r);

        cout << string((n - d) * 2, ' ');

        for(int i = 0; i <= d; i++) 
        {
            if(i) 
                cout << " ";
            cout << i;
        }
        for(int i = d - 1; i >= 0; i--) 
        {
            cout << " " << i;
        }

        cout << "\n";
    }

    return 0;
}
