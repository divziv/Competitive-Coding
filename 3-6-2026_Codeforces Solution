#include<bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long w, h;
        cin >> w >> h;

        long long s = 0;

        for(int i = 0; i < 4; i++)
        {
            int k;
            cin >> k;

            vector<long long> a(k);

            for(int j = 0; j < k; j++)
            {
                cin >> a[j];
            }

            s = max(s, (a.back() - a.front()) * (i < 2 ? h : w));
        }

        cout << s << "\n";
    }

    return 0;
}
