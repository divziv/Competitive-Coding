Solution:
#include<bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n, x;
        cin >> n >> x;

        vector<long long> v(n);
        for(auto &i : v)
        {
            cin >> i;
        }

        sort(v.begin(), v.end(), greater<long long>());

        long long c = 1, s = 0;

        for(int i = 0; i < n; ++i)
        {
            if(v[i] * c >= x)
            {
                ++s;
                c = 1;
            }
            else
            {
                ++c;
            }
        }

        cout << s << '\n';
    }

    return 0;
}
