#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n;
        cin >> n;

        vector<int> a(n);
        for(int i = 0; i < n; i++)
        {
            cin >> a[i];
        }

        set<int> s;
        int m = 0;

        for(int i = n - 1; i >= 0; i--)
        {
            if(s.count(a[i]))
            {
                m = i + 1;
                break;
            }
            s.insert(a[i]);
        }

        cout << m << "\n";
    }

    return 0;
}
