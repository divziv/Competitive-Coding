#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long n;
        cin >> n;

        vector<long long> a(n), p(n);
        long long s = 0;

        for(int i = 0; i < n; i++)
        {
            cin >> a[i];
            s += a[i];
            p[i] = a[i] + (i ? p[i - 1] : 0);
        }

        bool f = false;

        for(int i = 0; i < n; i++)
        {
            if(a[i] <= 0)
            {
                long long l = (i ? p[i] - a[i] : 0);
                long long r = p[n - 1] - a[i] - l;

                if(l >= s || r >= s)
                {
                    f = true;
                    break;
                }
            }
        }

        cout << (f ? "NO" : "YES") << '\n';
    }

    return 0;
}
