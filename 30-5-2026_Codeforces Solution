Solution:
#include<bits/stdc++.h>
using namespace std;

int main()
{
    string s;
    cin >> s;

    int cnt[26] = {0};
    int odd = 0;

    for(char c : s)
    {
        cnt[c - 'a']++;
    }

    for(int i = 0; i < 26; i++)
    {
        if(cnt[i] % 2)
        {
            odd++;
        }
    }

    if(odd == 0 || odd % 2 == 1)
    {
        cout << "First\n";
    }
    else
    {
        cout << "Second\n";
    }

    return 0;
}
