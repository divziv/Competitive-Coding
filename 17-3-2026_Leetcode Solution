Solution:
#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int largestSubmatrix(vector<vector<int>>& matrix) {
        int m = matrix.size();
        int n = matrix[0].size();
        
        for(int i = 1; i < m; i++) 
        {
            for(int j = 0; j < n; j++) 
            {
                if(matrix[i][j] == 1) 
                {
                    matrix[i][j] += matrix[i - 1][j];
                }
            }
        }
        
        int l = 0;
        
        for(int i = 0; i < m; i++) 
        {
            vector<int> h = matrix[i];
            sort(h.begin(), h.end(), greater<int>());
            
            for(int j = 0; j < n; j++) 
            {
                int a = h[j] * (j + 1);
                l = max(l, a);
            }
        }
        
        return l;
    }
};
