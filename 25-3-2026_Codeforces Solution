#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n;
        cin >> n;

        vector<long long> v(n);
        for(int i = 0; i < n; i++)
        {
            cin >> v[i];
            if(i % 2)
            {
                v[i] = -v[i];
            }
        }

        long long cs = 0;
        bool f = false;
        set<long long> s;
        s.insert(0);

        for(int i = 0; i < n; i++)
        {
            cs += v[i];
            if(s.count(cs))
            {
                f = true;
                break;
            }
            s.insert(cs);
        }

        cout << (f ? "YES\n" : "NO\n");
    }

    return 0;
}
