#include <bits/stdc++.h>
using namespace std;

int main()
{
    long t;
    cin >> t;
    while(t--)
    {
        long n;
        cin >> n;
        vector<long> f(n + 1, 0);
        for(long i = 0; i < n; i++)
        {
            long x;
            cin >> x;
            ++f[x];
        }
        long m = 0;
        for(long i = 0; i < (long)f.size(); i++)
        {
            m = max(m, f[i]);
        }
        cout << n - m << "\n";
    }
}
