#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long a, b;
        cin >> a >> b;

        if(a > b)
        {
            swap(a, b);
        }

        int s = 0;

        while(a < b)
        {
            if(b % 8 == 0 && b / 8 >= a)
            {
                b /= 8;
            }
            else if(b % 4 == 0 && b / 4 >= a)
            {
                b /= 4;
            }
            else if(b % 2 == 0 && b / 2 >= a)
            {
                b /= 2;
            }
            else
            {
                break;
            }
            s++;
        }

        if(a == b)
        {
            cout << s << "\n";
        }
        else
        {
            cout << -1 << "\n";
        }
    }

    return 0;
}
