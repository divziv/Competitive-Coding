#include <bits/stdc++.h>
using namespace std;

int main()
{
    long long t;
    cin >> t;
    while(t--)
    {
        long long n, x, y;
        cin >> n >> x >> y;

        map<pair<long long, long long>, set<long long>> mods;

        long long c = 0;
        for(long long p = 0; p < n; p++)
        {
            long long a;
            cin >> a;
            pair<long long, long long> key = {(x - (a % x)) % x, a % y};
            c += mods[key].size();
            mods[{a % x, a % y}].insert(p);
        }

        cout << c << "\n";
    }

    return 0;
}
