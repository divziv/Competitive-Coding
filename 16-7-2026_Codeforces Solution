#include <bits/stdc++.h>
using namespace std;

bool fair(long long n) {
    long long x = n;
    while(x > 0) 
    {
        int d = x % 10;
        if(d != 0 && n % d != 0)
            return false;
        x /= 10;
    }
    return true;
}

int main() {
    int t;
    cin >> t;

    while(t--) {
        long long n;
        cin >> n;

        while(!fair(n))
            n++;

        cout << n << "\n";
    }

    return 0;
}
