#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n, m, k;
        cin >> n >> m >> k;

        set<int> a, b;

        for(int i = 0; i < n; i++)
        {
            int x;
            cin >> x;
            if(x <= k)
            {
                a.insert(x);
            }
        }

        for(int i = 0; i < m; i++)
        {
            int x;
            cin >> x;
            if(x <= k)
            {
                b.insert(x);
            }
        }

        int oa = 0, ob = 0;
        bool f = true;

        for(int i = 1; i <= k; i++)
        {
            bool fa = a.count(i);
            bool fb = b.count(i);

            if(!fa && !fb)
            {
                f = false;
                break;
            }

            if(fa && !fb)
            {
                oa++;
            }

            if(!fa && fb)
            {
                ob++;
            }
        }

        if(f && oa <= k / 2 && ob <= k / 2)
        {
            cout << "YES\n";
        }
        else
        {
            cout << "NO\n";
        }
    }

    return 0;
}
