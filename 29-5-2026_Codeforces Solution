#include <bits/stdc++.h>
using namespace std;

int main() {
    long long n;
    cin >> n;

    vector<string> names = {
        "Sheldon", "Leonard", "Penny", "Rajesh", "Howard"
    };

    long long block = 1;

    while(n > 5 * block) 
    {
        n -= 5 * block;
        block *= 2;
    }

    int i = (n - 1) / block;

    cout << names[i] << "\n";

    return 0;
}
