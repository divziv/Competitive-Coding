#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long n, c;
        cin >> n >> c;

        vector<long long> a(n);

        for(long long i = 0; i < n; i++)
        {
            cin >> a[i];
            a[i] += (i + 1);
        }

        sort(a.begin(), a.end());

        long long m = 0;

        for(long long i = 0; i < n; i++)
        {
            if(a[i] <= c)
            {
                c -= a[i];
                m++;
            }
            else
            {
                break;
            }
        }

        cout << m << "\n";
    }

    return 0;
}
