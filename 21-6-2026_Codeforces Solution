#include <bits/stdc++.h>
using namespace std;

int main()
{
    long t;
    cin >> t;

    while(t--)
    {
        long n;
        cin >> n;

        vector<long> v(n, 0);

        for(long i = 0; i < n; i++)
        {
            cin >> v[i];
        }

        sort(v.begin(), v.end());
        v.push_back(1000000003);

        long p = v[0], c = 1, s = 0, r = 0;

        for(long i = 1; i <= n; i++)
        {
            if(v[i] == p)
            {
                ++c;
            }
            else
            {
                if(c < r)
                {
                    s += (r - c);
                    r = c;
                }
                else
                {
                    r = c;
                }

                if(v[i] > p + 1)
                {
                    s += r;
                    r = 0;
                }

                c = 1;
            }

            p = v[i];
        }

        cout << s << "\n";
    }

    return 0;
}
