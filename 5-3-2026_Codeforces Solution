Solution:
#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> v(n);
    for(int i = 0; i < n; i++) 
    {
        cin >> v[i];
    }

    int d = abs(v[0] - v[n - 1]);
    int idx = n - 1;

    for(int i = 0; i < n - 1; i++) 
    {
        if(abs(v[i] - v[i + 1]) < d) 
        {
            d = abs(v[i] - v[i + 1]);
            idx = i;
        }
    }

    cout << idx + 1 << " " << (idx + 1) % n + 1 << "\n";

    return 0;
}
