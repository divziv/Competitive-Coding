Solution:
#include <bits/stdc++.h>
using namespace std;

int main() {
    long long m = 1e9 + 7;

    long long t;
    cin >> t;

    while(t--) {
        long long n, k;
        cin >> n >> k;

        long long s = 1;

        for(long long i = 0; i < k; i++) 
        {
            s *= n;
            s %= m;
        }

        cout << s << "\n";
    }

    return 0;
}
