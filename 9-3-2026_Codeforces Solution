#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n, k;
        cin >> n >> k;

        vector<long long> a(n);
        for(int i = 0; i < n; i++) 
            cin >> a[i];

        sort(a.begin(), a.end());

        vector<long long> v(n);
        v[0] = a[0];

        for(int i = 1; i < n; i++)
            v[i] = v[i - 1] + a[i];

        long long s = v[n - 1 - k];

        for(int i = 1; i <= k; i++) 
        {
            long long c = v[n - 1 - k + i] - v[2 * i - 1];
            s = max(s, c);
        }

        cout << s << "\n";
    }

    return 0;
}
