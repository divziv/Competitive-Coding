#include <bits/stdc++.h>
using namespace std;

int main()
{
    long long t;
    cin >> t;

    while(t--)
    {
        long long n;
        cin >> n;

        long long d = 1;
        vector<long long> v;

        for(int i = 0; i < 17; i++)
        {
            d *= 10;
            if(n % (d + 1) != 0) 
                continue;
            v.push_back(n / (d + 1));
        }

        cout << v.size() << "\n";

        if(!v.empty())
        {
            sort(v.begin(), v.end());
            for(long long r : v)
            {
                cout << r << " ";
            }
            cout << "\n";
        }
    }

    return 0;
}
