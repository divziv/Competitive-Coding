#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        long long n;
        cin >> n;

        if(n <= 1)
        {
            cout << -1 << "\n";
        }
        else
        {
            cout << 2;

            for(long long i = 1; i < n; i++)
            {
                cout << 3;
            }

            cout << "\n";
        }
    }

    return 0;
}
