#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int l, r, x, y;
        cin >> l >> r >> x >> y;

        int a = max(l, x);
        int b = min(r, y);

        if(a > b) 
        {
            cout << 1 << "\n";
            continue;
        }

        int c = b - a;

        if(l != x) 
            c++;
        if(r != y) 
            c++;

        cout << c << "\n";
    }

    return 0;
}
