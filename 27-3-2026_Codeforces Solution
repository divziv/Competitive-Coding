#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n;
        cin >> n;

        string s;
        cin >> s;

        int c = 0;

        for(int i = 1; i < s.size(); i++)
        {
            if(s[i - 1] == '*' && s[i] == '*')
            {
                break;
            }
            if(s[i] == '@')
            {
                c++;
            }
        }

        cout << c << "\n";
    }

    return 0;
}
