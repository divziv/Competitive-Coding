#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        string s;
        cin >> s;

        int c = 0;
        for(int i = 0; i < s.size(); i++) 
        {
            if(s[i] == '0') 
                c++;
        }

        if(c == 1) 
        {
            cout << "BOB\n";
        } 
        else if(c % 2) 
        {
            cout << "ALICE\n";
        } 
        else 
        {
            cout << "BOB\n";
        }
    }

    return 0;
}
