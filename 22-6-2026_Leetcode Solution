Solution:
class Solution {
public:
    int maxNumberOfBalloons(string text)
    {
        vector<int> c(26, 0);
        
        for(char ch : text)
        {
            c[ch - 'a']++;
        }
        
        return min({
            c['b' - 'a'],
            c['a' - 'a'],
            c['l' - 'a'] / 2,
            c['o' - 'a'] / 2,
            c['n' - 'a']
        });
    }
};
