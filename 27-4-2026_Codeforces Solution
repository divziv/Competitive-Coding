#include <bits/stdc++.h>
using namespace std;

int main() {
    long long t;
    cin >> t;

    while (t--) {
        long long x, y, k;
        cin >> x >> y >> k;

        x = (x + k - 1) / k;
        y = (y + k - 1) / k;

        cout << 2 * max(x, y) - (x > y) << "\n";
    }

    return 0;
}
