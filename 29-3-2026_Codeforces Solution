#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;

    while(t--)
    {
        int n;
        cin >> n;

        int a, b;
        for(int i = 0; i < n; i++)
        {
            b = a;
            cin >> a;
        }

        if(n == 2 && abs(b - a) > 1)
        {
            cout << "YES\n";
        }
        else
        {
            cout << "NO\n";
        }
    }

    return 0;
}
