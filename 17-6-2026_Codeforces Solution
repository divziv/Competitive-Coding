Solution:
#include <bits/stdc++.h>
using namespace std;

int main()
{
    long t;
    cin >> t;

    while(t--)
    {
        long n, k;
        cin >> n >> k;

        vector<long> v(n);

        for(long i = 0; i < n; i++)
        {
            cin >> v[i];
        }

        sort(v.begin(), v.end());

        long l = 0, r = n - 1, c = 0;

        while(l < r)
        {
            long sum = v[l] + v[r];

            if(sum == k)
            {
                ++c;
                ++l;
                --r;
            }
            else if(sum < k)
            {
                ++l;
            }
            else
            {
                --r;
            }
        }

        cout << c << "\n";
    }

    return 0;
}
