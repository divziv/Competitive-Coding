#include <bits/stdc++.h>
using namespace std;

long computeXOR(long n) {
    if(n % 4 == 0) 
        return n;
    else if(n % 4 == 1) 
        return 1;
    else if(n % 4 == 2) 
        return n + 1;
    return 0;
}

int main() {
    long t;
    cin >> t;

    while(t--) {
        long a, b;
        cin >> a >> b;

        long x = computeXOR(a - 1);
        long s = a + 2;

        if(x == b) 
        {
            s = a;
        } 
        else if ((x ^ b) != a) 
        {
            s = a + 1;
        }

        cout << s << "\n";
    }

    return 0;
}
