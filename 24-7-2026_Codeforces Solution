#include <bits/stdc++.h>
using namespace std;

int main()
{
    int t;
    cin >> t;
    while (t--)
    {
        int n;
        cin >> n;
        vector<long long> a(n + 1);
        for(int i = 1; i <= n; i++)
            cin >> a[i];

        int p = -1;
        for(int i = 2; i <= n; i++)
        {
            if(a[i] != a[1])
            {
                p = i;
                break;
            }
        }

        if(p == -1)
        {
            cout << "NO\n";
            continue;
        }

        cout << "YES\n";
        for(int i = 2; i <= n; i++)
        {
            if(a[i] != a[1])
                cout << 1 << " " << i << "\n";
        }

        for(int i = 2; i <= n; i++)
        {
            if(a[i] == a[1])
                cout << p << " " << i << "\n";
        }
    }

    return 0;
}
