#include <bits/stdc++.h>
using namespace std;

int main()
{
    long long k2, k3, k5, k6;
    cin >> k2 >> k3 >> k5 >> k6;

    long long a = min({k2, k5, k6});
    long long b = min(k2 - a, k3);

    long long s = 256 * a + 32 * b;
    cout << s << "\n";

    return 0;
}
