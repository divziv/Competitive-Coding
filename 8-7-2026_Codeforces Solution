#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) 
    {
        vector<int> v(7);
        for(int &x : v) 
            cin >> x;

        sort(v.begin(), v.end());

        int s = v[6];
        for(int i = 0; i < 6; i++) 
            s -= v[i];

        cout << s << "\n";
    }

    return 0;
}
