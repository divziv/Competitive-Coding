#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        string x;
        cin >> x;

        bool f = false;
        string a = "", b = "";

        for(int i = 0; i < n; i++) 
        {
            if(x[i] == '0') 
            {
                a += '0';
                b += '0';
            } 
            else if(x[i] == '1') 
            {
                if(f) 
                {
                    a += '0';
                    b += '1';
                } 
                else 
                {
                    a += '1';
                    b += '0';
                    f = true;
                }
            } 
            else 
            {
                if(f) 
                {
                    a += '0';
                    b += '2';
                } 
                else 
                {
                    a += '1';
                    b += '1';
                }
            }
        }

        cout << a << "\n";
        cout << b << "\n";
    }

    return 0;
}
