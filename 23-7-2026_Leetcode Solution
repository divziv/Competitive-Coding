Problem Link:
https://leetcode.com/problems/number-of-unique-xor-triplets-i/?envType=daily-question&envId=2026-07-23

Solution:
class Solution {
public:
    int uniqueXorTriplets(vector<int>& nums) {
        int n = nums.size();

        if(n <= 2) 
            return n;

        int s = 1;
        while(s <= n) 
            s <<= 1;
        return s;
    }
};
